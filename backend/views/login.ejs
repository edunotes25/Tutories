<!-- Script principal - SIN type="module" para evitar problemas -->
<script>
// Configuración de Firebase
const firebaseConfig = {
    apiKey: "AIzaSyBn_qSBGxQh-Gp8laagdzYAKPfKuNHho7s",
    authDomain: "tutories-679c5.firebaseapp.com",
    projectId: "tutories-679c5",
    storageBucket: "tutories-679c5.firebasestorage.app",
    messagingSenderId: "1025787276190",
    appId: "1:1025787276190:web:eaa4f1c523639f1d66848f"
};

console.log('✅ Script cargado correctamente');

// Cargar Firebase de forma tradicional
function loadFirebase() {
    return new Promise((resolve) => {
        // Verificar si ya está cargado
        if (window.firebase) {
            resolve(window.firebase);
            return;
        }
        
        // Cargar Firebase app
        const scriptApp = document.createElement('script');
        scriptApp.src = 'https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js';
        scriptApp.onload = () => {
            // Cargar Firebase auth
            const scriptAuth = document.createElement('script');
            scriptAuth.src = 'https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js';
            scriptAuth.onload = () => {
                console.log('✅ Firebase cargado');
                resolve(window.firebase);
            };
            document.head.appendChild(scriptAuth);
        };
        document.head.appendChild(scriptApp);
    });
}

// Inicializar cuando todo esté listo
document.addEventListener('DOMContentLoaded', async () => {
    console.log('📝 DOM cargado, inicializando...');
    
    const firebase = await loadFirebase();
    
    if (!firebase.apps.length) {
        firebase.initializeApp(firebaseConfig);
    }
    
    const auth = firebase.auth();
    console.log('✅ Firebase inicializado');
    
    // Elementos del DOM
    const urlParams = new URLSearchParams(window.location.search);
    const tipo = urlParams.get('tipo') || 'padre';
    const titulo = document.getElementById('tituloLogin');
    const registroLink = document.getElementById('registroLink');
    const tipoInput = document.getElementById('tipoInput');
    const loginForm = document.getElementById('login-form');
    const firebaseError = document.getElementById('firebase-error');
    const firebaseSuccess = document.getElementById('firebase-success');
    const loadingSpinner = document.getElementById('loading-spinner');
    const submitBtn = document.getElementById('submit-btn');
    
    // Configurar según tipo
    tipoInput.value = tipo;
    
    if (tipo === 'profesor') {
        titulo.innerText = 'Iniciar Sesión - Profesor';
        registroLink.innerHTML = '¿No tienes cuenta? <a href="/registro">Regístrate como profesor</a>';
    } else {
        titulo.innerText = 'Iniciar Sesión - Padre/Madre';
        registroLink.innerHTML = '¿No tienes cuenta? <a href="/registro-padre">Regístrate como padre</a>';
    }
    
    function showMessage(element, message, isSuccess = false) {
        firebaseError.style.display = 'none';
        firebaseSuccess.style.display = 'none';
        element.textContent = message;
        element.style.display = 'block';
        setTimeout(() => element.style.display = 'none', 5000);
    }
    
    function setLoading(isLoading) {
        if (isLoading) {
            loadingSpinner.style.display = 'block';
            submitBtn.disabled = true;
            submitBtn.textContent = 'Iniciando sesión...';
        } else {
            loadingSpinner.style.display = 'none';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Iniciar Sesión';
        }
    }
    
    // Manejar login
    loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        console.log('🚀 Submit capturado!');
        
        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;
        const tipo = tipoInput.value;
        
        if (!email || !password) {
            showMessage(firebaseError, 'Completa todos los campos');
            return;
        }
        
        setLoading(true);
        
        try {
            console.log('Intentando login con:', email);
            const userCredential = await auth.signInWithEmailAndPassword(email, password);
            console.log('✅ Login exitoso:', userCredential.user.uid);
            
            const idToken = await userCredential.user.getIdToken();
            
            const response = await fetch('/auth/verify-login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ idToken, tipo })
            });
            
            const data = await response.json();
            
            if (data.success) {
                showMessage(firebaseSuccess, '¡Login exitoso! Redirigiendo...', true);
                setTimeout(() => window.location.href = data.redirect, 1000);
            } else {
                await auth.signOut();
                showMessage(firebaseError, data.error || 'Error de verificación');
                setLoading(false);
            }
        } catch (error) {
            setLoading(false);
            console.error('Error:', error);
            
            let mensaje = 'Error al iniciar sesión';
            if (error.code === 'auth/user-not-found') mensaje = 'Usuario no encontrado';
            else if (error.code === 'auth/wrong-password') mensaje = 'Contraseña incorrecta';
            else if (error.code === 'auth/invalid-email') mensaje = 'Email inválido';
            else if (error.code === 'auth/too-many-requests') mensaje = 'Demasiados intentos';
            else if (error.code === 'auth/invalid-credential') mensaje = 'Credenciales inválidas';
            
            showMessage(firebaseError, mensaje);
        }
    });
    
    console.log('✅ Evento submit asignado');
});
</script>