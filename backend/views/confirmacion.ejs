<div class="confirmacion-container">
    <div class="confirmacion-icono">✓</div>
    
    <h1><%= __('reserva_confirmada') %></h1>
    
    <div class="confirmacion-detalles">
        <h2><%= __('detalles_tutoria') %></h2>
        
        <div class="detalle-item">
            <span class="detalle-label"><%= __('profesor') %>:</span>
            <span class="detalle-valor"><%= reserva.profesorNombre %></span>
        </div>
        
        <div class="detalle-item">
            <span class="detalle-label"><%= __('fecha') %>:</span>
            <span class="detalle-valor"><%= new Date(reserva.fecha).toLocaleDateString(__('locale_date'), { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        </div>
        
        <div class="detalle-item">
            <span class="detalle-label"><%= __('hora') %>:</span>
            <span class="detalle-valor"><%= reserva.hora %></span>
        </div>
        
        <div class="detalle-item">
            <span class="detalle-label"><%= __('id_reserva') %>:</span>
            <span class="detalle-valor"><%= reserva.id.substring(0, 8).toUpperCase() %></span>
        </div>
    </div>
    
    <div class="confirmacion-acciones">
        <p><%= __('email_confirmacion_enviado') %> <strong><%= reserva.emailPadre %></strong> <%= __('con_pdf_adjunto') %></p>
        
        <div class="botones-accion">
            <button onclick="window.print()" class="btn btn-secondary">
                🖨️ <%= __('imprimir_confirmacion') %>
            </button>
            <a href="/" class="btn btn-primary">
                <%= __('volver_inicio') %>
            </a>
        </div>
    </div>
    
    <div class="info-rgpd">
        <p>
            <strong><%= __('importante_rgpd') %>:</strong> <%= __('texto_rgpd_completo') %>
        </p>
    </div>
</div>