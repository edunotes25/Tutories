<div class="aviso-privacidad">
    <h1><%= __('aviso_privacidad') %></h1>
    
    <div class="fecha-actualizacion">
        <%= __('ultima_actualizacion') %>: <%= new Date().toLocaleDateString(__('locale_date')) %>
    </div>
    
    <section class="seccion">
        <h2><%= __('responsable_titulo') %></h2>
        <p>
            <%= __('responsable_texto') %>
        </p>
    </section>
    
    <section class="seccion">
        <h2><%= __('finalidad_titulo') %></h2>
        <p><%= __('finalidad_texto') %></p>
        <ul>
            <li><%= __('finalidad_1') %></li>
            <li><%= __('finalidad_2') %></li>
            <li><%= __('finalidad_3') %></li>
        </ul>
    </section>
    
    <section class="seccion">
        <h2><%= __('base_legal_titulo') %></h2>
        <p>
            <%= __('base_legal_texto') %>
        </p>
    </section>
    
    <section class="seccion">
        <h2><%= __('datos_titulo') %></h2>
        <p><%= __('datos_texto') %></p>
        <ul>
            <li><%= __('datos_1') %></li>
            <li><%= __('datos_2') %></li>
            <li><%= __('datos_3') %></li>
            <li><%= __('datos_4') %></li>
        </ul>
    </section>
    
    <section class="seccion">
        <h2><%= __('conservacion_titulo') %></h2>
        <p>
            <%= __('conservacion_texto') %>
        </p>
    </section>
    
    <section class="seccion">
        <h2><%= __('destinatarios_titulo') %></h2>
        <p>
            <%= __('destinatarios_texto') %>
        </p>
    </section>
    
    <section class="seccion">
        <h2><%= __('derechos_titulo') %></h2>
        <p><%= __('derechos_texto') %></p>
        <ul>
            <li><strong><%= __('derecho_acceso') %>:</strong> <%= __('derecho_acceso_texto') %></li>
            <li><strong><%= __('derecho_rectificacion') %>:</strong> <%= __('derecho_rectificacion_texto') %></li>
            <li><strong><%= __('derecho_supresion') %>:</strong> <%= __('derecho_supresion_texto') %></li>
            <li><strong><%= __('derecho_oposicion') %>:</strong> <%= __('derecho_oposicion_texto') %></li>
            <li><strong><%= __('derecho_limitacion') %>:</strong> <%= __('derecho_limitacion_texto') %></li>
            <li><strong><%= __('derecho_portabilidad') %>:</strong> <%= __('derecho_portabilidad_texto') %></li>
        </ul>
        <p>
            <%= __('derechos_ejercicio') %>
        </p>
    </section>
    
    <section class="seccion">
        <h2><%= __('consentimiento_titulo') %></h2>
        <p>
            <%= __('consentimiento_texto') %>
        </p>
    </section>
    
    <form action="/consentimiento" method="POST" class="consentimiento-form">
        <button type="submit" name="aceptar" value="true" class="btn btn-primary">
            <%= __('aceptar_continuar') %>
        </button>
    </form>
</div>