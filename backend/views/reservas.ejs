<div class="reserva-header">
    <h1>Reservar tutoría con <%= profesor.nombre %></h1>
    <a href="/" class="btn btn-secondary">← Volver</a>
</div>

<div class="reserva-container">
    <div class="calendario-section">
        <h2>Seleccionar fecha</h2>
        
        <div class="calendario-navegacion">
            <button class="btn-nav" onclick="cambiarSemana(-1)">← Semana anterior</button>
            <span class="semana-actual" id="semanaActual"></span>
            <button class="btn-nav" onclick="cambiarSemana(1)">Semana siguiente →</button>
        </div>
        
        <div class="calendario-grid" id="calendario">
            <!-- Generado dinámicamente con JS -->
        </div>
    </div>
    
    <div class="formulario-section">
        <h2>Datos de la reserva</h2>
        
        <div class="reserva-info" id="reservaInfo" style="display: none;">
            <p><strong>Profesor:</strong> <%= profesor.nombre %></p>
            <p><strong>Fecha:</strong> <span id="fechaSeleccionada"></span></p>
            <p><strong>Hora:</strong> <span id="horaSeleccionada"></span></p>
        </div>
        
        <form id="formularioReserva" class="formulario-reserva" style="display: none;">
            <input type="hidden" name="profesorId" value="<%= profesor.id %>">
            <input type="hidden" name="fecha" id="fechaInput">
            <input type="hidden" name="hora" id="horaInput">
            
            <div class="form-group">
                <label for="nombrePadre">Nombre del padre/madre/tutor *</label>
                <input type="text" id="nombrePadre" name="nombrePadre" required 
                       placeholder="Ej: María García López">
            </div>
            
            <div class="form-group">
                <label for="emailPadre">Email *</label>
                <input type="email" id="emailPadre" name="emailPadre" required 
                       placeholder="ejemplo@correo.com">
                <small>Le enviaremos la confirmación a esta dirección</small>
            </div>
            
            <div class="form-group">
                <label for="telefono">Teléfono (opcional)</label>
                <input type="tel" id="telefono" name="telefono" 
                       placeholder="600 123 456">
            </div>
            
            <div class="form-group">
                <label for="comentarios">Comentarios (opcional)</label>
                <textarea id="comentarios" name="comentarios" rows="3" 
                          placeholder="¿Alguna observación para el profesor?"></textarea>
            </div>
            
            <div class="form-group consentimiento">
                <input type="checkbox" id="aceptaCondiciones" name="aceptaCondiciones" required>
                <label for="aceptaCondiciones">
                    He leído y acepto el <a href="/aviso-privacidad" target="_blank">aviso de privacidad</a> 
                    y consiento el tratamiento de mis datos para esta reserva *
                </label>
            </div>
            
            <button type="submit" class="btn btn-primary btn-block">Confirmar reserva</button>
        </form>
        
        <div id="mensajeAlerta" class="alerta" style="display: none;"></div>
    </div>
</div>

<script>
    // Datos iniciales pasados desde el servidor
    const horariosProfesor = <%- JSON.stringify(horarios) %>;
    const reservasExistentes = <%- JSON.stringify(reservas) %>;
    const profesorId = '<%= profesor.id %>';
</script>
