<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('cancelar_reserva_titulo') %> - <%= __('titulo') %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .cancelar-container {
            max-width: 600px;
            width: 100%;
        }
        
        .cancelar-card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        
        .cancelar-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        .cancelar-icono {
            width: 70px;
            height: 70px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 15px;
        }
        
        .cancelar-header h1 {
            margin: 0;
            font-size: 1.8rem;
        }
        
        .cancelar-body {
            padding: 30px;
        }
        
        .cancelar-intro {
            text-align: center;
            font-size: 1.1rem;
            color: #666;
            margin-bottom: 25px;
        }
        
        .detalle-reserva {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 25px;
            border-left: 4px solid #ffc107;
        }
        
        .detalle-reserva h2 {
            color: #4a90e2;
            font-size: 1.2rem;
            margin-top: 0;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid #dee2e6;
        }
        
        .detalle-item {
            display: flex;
            padding: 8px 0;
            border-bottom: 1px solid #e9ecef;
        }
        
        .detalle-item:last-child {
            border-bottom: none;
        }
        
        .detalle-label {
            flex: 0 0 100px;
            font-weight: 600;
            color: #495057;
        }
        
        .detalle-valor {
            flex: 1;
            color: #212529;
        }
        
        .cancelar-acciones {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .btn {
            display: inline-block;
            padding: 12px 20px;
            border: none;
            border-radius: 5px;
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            transition: all 0.3s;
        }
        
        .btn-danger {
            background: #dc3545;
            color: white;
        }
        
        .btn-danger:hover:not(:disabled) {
            background: #c82333;
            transform: translateY(-2px);
        }
        
        .btn-danger:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        .btn-secondary {
            background: #6c757d;
            color: white;
        }
        
        .btn-secondary:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }
        
        .btn-block {
            display: block;
            width: 100%;
        }
        
        .cancelar-info {
            background: #fff3cd;
            border: 1px solid #ffeeba;
            border-radius: 5px;
            padding: 15px;
            color: #856404;
            font-size: 0.9rem;
        }
        
        .cancelar-info p {
            margin: 0;
        }
        
        .error-mensaje {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
            padding: 15px;
            border-radius: 5px;
            margin-bottom: 20px;
            text-align: center;
        }
        
        @media (max-width: 480px) {
            .detalle-item {
                flex-direction: column;
            }
            
            .detalle-label {
                flex: none;
                margin-bottom: 5px;
            }
            
            .cancelar-header h1 {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="cancelar-container">
        <div class="cancelar-card">
            <div class="cancelar-header">
                <div class="cancelar-icono">❓</div>
                <h1><%= __('cancelar_reserva') %></h1>
            </div>
            
            <div class="cancelar-body">
                <% if (error && error.length > 0) { %>
                    <div class="error-mensaje"><%= error %></div>
                <% } %>
                
                <p class="cancelar-intro"><%= __('cancelar_confirmacion') %></p>
                
                <div class="detalle-reserva">
                    <h2><%= __('detalles_reserva') %></h2>
                    
                    <div class="detalle-item">
                        <span class="detalle-label"><%= __('profesor') %>:</span>
                        <span class="detalle-valor"><%= reserva.profesorNombre || __('no_especificado') %></span>
                    </div>
                    
                    <div class="detalle-item">
                        <span class="detalle-label"><%= __('alumno') %>:</span>
                        <span class="detalle-valor"><%= reserva.nombreAlumno || __('no_especificado') %></span>
                    </div>
                    
                    <div class="detalle-item">
                        <span class="detalle-label"><%= __('fecha') %>:</span>
                        <span class="detalle-valor"><%= new Date(reserva.fecha).toLocaleDateString(__('locale_date'), { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                    </div>
                    
                    <div class="detalle-item">
                        <span class="detalle-label"><%= __('hora') %>:</span>
                        <span class="detalle-valor"><%= reserva.hora %></span>
                    </div>
                    
                    <div class="detalle-item">
                        <span class="detalle-label"><%= __('id_reserva') %>:</span>
                        <span class="detalle-valor"><%= reserva.reservaId.substring(0, 8).toUpperCase() %></span>
                    </div>
                </div>
                
                <div class="cancelar-acciones">
                    <form action="/cancelar/<%= token %>" method="POST" id="formCancelar">
                        <button type="submit" class="btn btn-danger btn-block" onclick="return confirm('<%= __('confirmar_cancelacion') %>')">
                            <%= __('si_cancelar') %>
                        </button>
                    </form>
                    
                    <a href="/" class="btn btn-secondary btn-block"><%= __('no_volver_inicio') %></a>
                </div>
                
                <div class="cancelar-info">
                    <p><strong><%= __('importante') %>:</strong> <%= __('info_cancelacion') %></p>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Prevenir doble envío del formulario
        const form = document.getElementById('formCancelar');
        if (form) {
            form.addEventListener('submit', function() {
                const btn = this.querySelector('button');
                btn.disabled = true;
                btn.textContent = '<%= __('cancelando') %>';
            });
        }
    </script>
</body>
</html>