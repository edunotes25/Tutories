<div class="form-group">
    <label for="hora">Hora de la tutoría:</label>
    
    <div class="hora-selector">
        <!-- Select con horas predefinidas -->
        <select name="hora_select" id="hora_select" class="form-control mb-2">
            <option value="">Selecciona una hora</option>
            <% for(let hora = 9; hora <= 20; hora++) { %>
                <option value="<%= hora.toString().padStart(2, '0') %>:00">
                    <%= hora.toString().padStart(2, '0') %>:00
                </option>
            <% } %>
            <option value="custom">✏️ Otra hora (personalizada)</option>
        </select>
        
        <!-- Input para hora personalizada -->
        <div id="custom_hora_container" style="display: none;" class="mb-2">
            <input type="time" 
                   name="hora_custom" 
                   id="hora_custom" 
                   class="form-control" 
                   step="1800" <!-- 30 minutos -->
                   min="00:00" 
                   max="23:30">
            <small class="text-muted">Formato: HH:MM (ej: 14:30, 18:45)</small>
        </div>
        
        <!-- Campo oculto que enviará el valor final -->
        <input type="hidden" name="hora" id="hora_final">
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const select = document.getElementById('hora_select');
    const customContainer = document.getElementById('custom_hora_container');
    const customInput = document.getElementById('hora_custom');
    const horaFinal = document.getElementById('hora_final');
    
    // Función para actualizar el campo oculto
    function actualizarHoraFinal() {
        if (select.value === 'custom') {
            if (customInput.value) {
                horaFinal.value = customInput.value;
            } else {
                horaFinal.value = '';
            }
        } else {
            horaFinal.value = select.value;
        }
    }
    
    // Evento para cuando cambia el select
    select.addEventListener('change', function() {
        if (this.value === 'custom') {
            customContainer.style.display = 'block';
            customInput.required = true;
            select.required = false;
            horaFinal.value = ''; // Limpiar mientras escribe
        } else {
            customContainer.style.display = 'none';
            customInput.required = false;
            customInput.value = ''; // Limpiar input
            horaFinal.value = this.value; // Usar valor del select
        }
    });
    
    // Evento para cuando escribe en el input personalizado
    customInput.addEventListener('input', function() {
        if (select.value === 'custom') {
            horaFinal.value = this.value;
        }
    });
    
    // Validación al enviar el formulario
    const form = document.getElementById('form-horario'); // Ajusta el ID de tu formulario
    if (form) {
        form.addEventListener('submit', function(e) {
            if (!horaFinal.value) {
                e.preventDefault();
                alert('Por favor, selecciona o escribe una hora válida');
                return false;
            }
            
            // Validar formato de hora (HH:MM)
            const horaRegex = /^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$/;
            if (!horaRegex.test(horaFinal.value)) {
                e.preventDefault();
                alert('La hora debe tener formato HH:MM (ej: 14:30, 09:00)');
                return false;
            }
        });
    }
});
</script>

<style>
.hora-selector {
    background: #f8f9fa;
    padding: 15px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
}

.hora-selector select,
.hora-selector input {
    width: 100%;
    padding: 10px;
    border: 2px solid #e9ecef;
    border-radius: 6px;
    transition: all 0.3s;
}

.hora-selector select:focus,
.hora-selector input:focus {
    border-color: #4a90e2;
    outline: none;
    box-shadow: 0 0 0 3px rgba(74,144,226,0.1);
}

.text-muted {
    color: #6c757d;
    font-size: 0.875em;
    margin-top: 5px;
    display: block;
}
</style>