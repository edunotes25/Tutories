    border-radius: 10px;
    border: 1px solid #e9ecef;
}

.formulari-reserva h3 {
    color: #4a90e2;
    margin-bottom: 20px;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
