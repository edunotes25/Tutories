    padding: 15px;
    border-radius: 5px;
    margin-bottom: 20px;
}

.alerta.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}

.alerta.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}
</style>

<script>
// Variables globals
let dataSeleccionada = null;
let horaSeleccionada = null;
let setmanaActual = new Date();

// Dades d'horaris i reserves des del servidor
const horarisProfessor = <%- JSON.stringify(horaris) %>;
const reservesExistents = <%- JSON.stringify(reserves) %>;
const professorId = '<%= professor.uid %>';

console.log('=== DADES REBUDES ===');
console.log('Horaris:', horarisProfessor);
console.log('Reserves:', reservesExistents);

// Dies de la setmana en català
const diesSetmana = ['Dilluns', 'Dimarts', 'Dimecres', 'Dijous', 'Divendres', 'Dissabte', 'Diumenge'];

// Inicialitzar calendari
document.addEventListener('DOMContentLoaded', function() {
    renderitzarCalendari(setmanaActual);
    
    // Event listeners per als botons
    document.getElementById('btnSetmanaAnterior').addEventListener('click', function() {
        canviarSetmana(-1);
    });
    
    document.getElementById('btnSetmanaSeguent').addEventListener('click', function() {
        canviarSetmana(1);
    });
    
    // Event listener per al formulari
    document.getElementById('formReserva').addEventListener('submit', function(e) {
        e.preventDefault();
        processarReserva();
    });
});

// Canviar setmana
function canviarSetmana(direccio) {
    setmanaActual.setDate(setmanaActual.getDate() + (direccio * 7));
    renderitzarCalendari(setmanaActual);
}

// Renderitzar calendari
function renderitzarCalendari(data) {
    const calendari = document.getElementById('calendari');
    if (!calendari) return;
    
    const iniciSetmana = new Date(data);
    iniciSetmana.setDate(data.getDate() - data.getDay() + 1); // Començar en dilluns
    
    let html = '';
    
    // Dies de la setmana
    diesSetmana.forEach(dia => {
        html += `<div class="dia-header">${dia}</div>`;
    });
    
    // Generar dies
    for (let i = 0; i < 7; i++) {
        const dia = new Date(iniciSetmana);
        dia.setDate(iniciSetmana.getDate() + i);
        
        const dataStr = dia.toISOString().split('T')[0];
        const diaMes = dia.getDate();
        const diaSetmanaIdx = dia.getDay(); // 0 = diumenge, 1 = dilluns, ...
        
        // Ajustar perquè dilluns sigui 1, dimarts 2, etc.
        let diaSetmanaAjustat = diaSetmanaIdx === 0 ? 7 : diaSetmanaIdx;
        
        html += `<div class="dia-celda" data-data="${dataStr}">`;
        html += `<div class="dia-numero">${diaMes}</div>`;
        
        // Filtrar horaris per a aquest dia de la setmana
        const horarisDia = horarisProfessor.filter(h => h.diaSetmana === diaSetmanaAjustat);
        
        // Ordenar hores
        const horesOrdenades = horarisDia.map(h => h.hora).sort();
        
        if (horesOrdenades.length === 0) {
            html += `<div class="sense-horaris">-</div>`;
        } else {
            horesOrdenades.forEach(hora => {
                // Verificar si aquesta hora ja està reservada
                const reservada = reservesExistents.some(r => 
                    r.data === dataStr && r.hora === hora && r.estat !== 'cancel·lada'
                );
                
                // Aplicar classe reservada si correspon (es veurà en VERMELL)
                const classe = `hora-item ${reservada ? 'reservada' : ''}`;
                
                // Si està reservada, no es pot seleccionar
                const onclick = reservada ? '' : `seleccionarHorari('${dataStr}', '${hora}')`;
                
                html += `<div class="${classe}" onclick="${onclick}">${hora}</div>`;
            });
        }
        
        html += '</div>';
    }
    
    calendari.innerHTML = html;
    
    // Actualitzar text de setmana
    const setmanaActualEl = document.getElementById('setmanaActual');
    if (setmanaActualEl) {
        const fiSetmana = new Date(iniciSetmana);
        fiSetmana.setDate(iniciSetmana.getDate() + 6);
        
        setmanaActualEl.textContent = `${iniciSetmana.toLocaleDateString('ca-ES')} - ${fiSetmana.toLocaleDateString('ca-ES')}`;
    }
}

// Seleccionar horari
function seleccionarHorari(data, hora) {
    dataSeleccionada = data;
    horaSeleccionada = hora;
    
    // Actualitzar UI - treure selecció anterior
    document.querySelectorAll('.hora-item').forEach(el => {
        el.classList.remove('seleccionada');
    });
    
    // Marcar l'hora seleccionada
    event.target.classList.add('seleccionada');
    
    // Mostrar formulari i reserva seleccionada
    document.getElementById('formulariReserva').style.display = 'block';
    document.getElementById('reservaSeleccionada').style.display = 'block';
    document.getElementById('dataSeleccionada').textContent = new Date(data).toLocaleDateString('ca-ES');
    document.getElementById('horaSeleccionada').textContent = hora;
    
    // Actualitzar camps ocults
    document.getElementById('dataInput').value = data;
    document.getElementById('horaInput').value = hora;
}

// Processar reserva
function processarReserva() {
    // Validar consentiment
    if (!document.getElementById('acceptaCondicions').checked) {
        mostrarAlerta('Has d\'acceptar l\'avís de privacitat', 'error');
        return;
    }
    
    // Validar que hi ha una hora seleccionada
    if (!dataSeleccionada || !horaSeleccionada) {
        mostrarAlerta('Si us plau, selecciona una data i hora', 'error');
        return;
    }
    
    // Recollir dades del formulari
    const formData = new FormData(document.getElementById('formReserva'));
    const data = Object.fromEntries(formData.entries());
    
    // Mostrar missatge de càrrega
    mostrarAlerta('Processant reserva...', 'info');
    
    // Enviar reserva
    fetch('/api/pare/reservar', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            mostrarAlerta('Reserva confirmada! Redirigint...', 'success');
            setTimeout(() => {
                window.location.href = `/confirmacio/${data.reservaId}`;
            }, 2000);
        } else {
            mostrarAlerta(data.error || 'Error en crear la reserva', 'error');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        mostrarAlerta('Error en processar la reserva', 'error');
    });
}

// Mostrar alerta
function mostrarAlerta(missatge, tipus) {
    const alerta = document.getElementById('missatgeAlerta');
    alerta.textContent = missatge;
    alerta.className = `alerta ${tipus}`;
    alerta.style.display = 'block';
    
    // Ocultar després de 5 segons
    setTimeout(() => {
        alerta.style.display = 'none';
    }, 5000);
}
</script>