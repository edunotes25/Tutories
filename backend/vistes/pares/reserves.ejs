<div class="dashboard-header">
    <h1>Reservar tutoria amb <%= professor.nom %></h1>
    <div>
        <a href="/pare/professors" class="btn btn-secondary">← Tornar a professors</a>
        <a href="/logout" class="btn btn-secondary">Tancar sessió</a>
    </div>
</div>

<% if (error && error.length > 0) { %>
    <div class="alerta error"><%= error %></div>
<% } %>

<% if (success && success.length > 0) { %>
    <div class="alerta success"><%= success %></div>
<% } %>

<div class="professor-info">
    <div class="info-card">
        <h2>Informació del professor</h2>
        <p><strong>Nom:</strong> <%= professor.nom %></p>
        <p><strong>Email:</strong> <%= professor.email %></p>
        <p><strong>Curs que imparteix:</strong> <%= professor.curs || 'No especificat' %></p>
        <% if (professor.descripcio) { %>
            <p><strong>Descripció:</strong> <%= professor.descripcio %></p>
        <% } %>
    </div>
</div>

<div class="alumne-info">
    <div class="info-card">
        <h2>Dades de l'alumne</h2>
        <p><strong>Nom de l'alumne:</strong> <span id="nomAlumneDisplay"><%= usuari.nomAlumne || 'No especificat' %></span></p>
    </div>
</div>

<div class="reserves-container">
    <h2>Selecciona data i hora</h2>
    
    <!-- Llegenda de colors -->
    <div class="llegenda">
        <div class="llegenda-item">
            <span class="color-disponible"></span>
            <span>Disponible</span>
        </div>
        <div class="llegenda-item">
            <span class="color-reservada"></span>
            <span>Reservada</span>
        </div>
        <div class="llegenda-item">
            <span class="color-seleccionada"></span>
            <span>Seleccionada</span>
        </div>
    </div>
    
    <!-- Calendari de selecció de data -->
    <div class="calendari-container">
        <div class="calendari-navegacio">
            <button class="btn-nav" id="btnSetmanaAnterior">← Setmana anterior</button>
            <span class="setmana-actual" id="setmanaActual"></span>
            <button class="btn-nav" id="btnSetmanaSeguent">Setmana següent →</button>
        </div>
        
        <div class="calendari-grid" id="calendari">
            <!-- Es genera dinàmicament amb JavaScript -->
        </div>
    </div>
    
    <!-- Formulari de reserva (ocult fins seleccionar hora) -->
    <div class="formulari-reserva" id="formulariReserva" style="display: none;">
        <h3>Confirma les dades de la reserva</h3>
        
        <form id="formReserva">
            <input type="hidden" name="professorId" value="<%= professor.uid %>">
            <input type="hidden" name="data" id="dataInput">
            <input type="hidden" name="hora" id="horaInput">
            
            <div class="form-group">
                <label for="nomPare">El teu nom (pare/mare)</label>
                <input type="text" id="nomPare" name="nomPare" readonly 
                       value="<%= usuari.nom || '' %>">
            </div>
            
            <div class="form-group">
                <label for="nomAlumne">Nom de l'alumne</label>
                <input type="text" id="nomAlumne" name="nomAlumne" readonly 
                       value="<%= usuari.nomAlumne || '' %>">
            </div>
            
            <div class="form-group">
                <label for="emailPare">El teu email</label>
                <input type="email" id="emailPare" name="emailPare" readonly 
                       value="<%= usuari.email || '' %>">
            </div>
            
            <div class="form-group">
                <label for="telefon">Telèfon de contacte</label>
                <input type="tel" id="telefon" name="telefon" 
                       value="<%= usuari.telefon || '' %>" readonly>
            </div>
            
            <div class="form-group">
                <label for="comentaris">Comentaris (opcional)</label>
                <textarea id="comentaris" name="comentaris" rows="3" 
                          placeholder="Alguna cosa que vulguis comentar al professor?"></textarea>
            </div>
            
            <div class="form-group consentiment">
                <input type="checkbox" id="acceptaCondicions" required>
                <label for="acceptaCondicions">
                    He llegit i accepto l'<a href="/avis-privacitat" target="_blank">avís de privacitat</a>
                </label>
            </div>
            
            <button type="submit" class="btn btn-primary btn-block">Confirmar reserva</button>
        </form>
        
        <div id="missatgeAlerta" class="alerta" style="display: none;"></div>
    </div>
    
    <!-- Informació de la reserva seleccionada -->
    <div class="reserva-seleccionada" id="reservaSeleccionada" style="display: none;">
        <h3>Reserva seleccionada</h3>
        <p><strong>Data:</strong> <span id="dataSeleccionada"></span></p>
        <p><strong>Hora:</strong> <span id="horaSeleccionada"></span></p>
        <p><strong>Alumne:</strong> <span id="alumneSeleccionat"><%= usuari.nomAlumne || '' %></span></p>
    </div>
</div>

<style>
